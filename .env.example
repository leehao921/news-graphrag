# ─────────────────────────────────────────────────────────────────────
# news-graphrag 環境變數
# 複製為 .env 並填入實際值
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# ── 資料庫密碼 ──────────────────────────────────────────────────────
NEO4J_PASSWORD=your_neo4j_password_here
POSTGRES_DB=newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=your_postgres_password_here

# ── 應用設定 ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
EMBEDDING_MODEL=bge-m3
LLM_MODEL=qwen2.5:7b
VECTOR_TRANSFER_ALPHA=0.3          # 向量轉移強度（0=純向量, 1=純圖）

# ── 爬蟲設定 ────────────────────────────────────────────────────────
CRAWL_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_CRAWL=100
DEDUP_TTL_DAYS=7

# ── 可選：外部 API（若需要爬取付費資料源）──────────────────────────
# CNYES_API_KEY=
# REUTERS_API_KEY=

# ── MinIO 物件儲存 ───────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_secret_here
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_RAW=raw-articles

# ── SiYuan 思源筆記 ──────────────────────────────────────────────────
SIYUAN_URL=http://localhost:6806
SIYUAN_TOKEN=graphrag2026          # Access Auth Code（首次設定後修改）
SIYUAN_NOTEBOOK_GRAPHRAG=          # 執行 python src/knowledge/siyuan_client.py --init 後填入

# ── n8n 設定 ────────────────────────────────────────────────────────
N8N_PORT=5678
# N8N_SMTP_HOST=smtp.gmail.com  # 選填
# N8N_SMTP_USER=your@email.com  # 選填

# ── TMF 交易系統整合 ─────────────────────────────────────────────────
TMF_REDIS_URL=redis://localhost:6379/1   # TMF 系統的 Redis（不同 DB）
NEWS_SENTIMENT_STREAM=tmf:stream:news_sentiment

# ─────────────────────────────────────────────────────────
# SiYuan 思源筆記 (知識庫)
# http://localhost:6806
# ─────────────────────────────────────────────────────────
SIYUAN_URL=http://siyuan:6806
SIYUAN_TOKEN=graphrag2026

# 首次 init 後填入 (POST /knowledge/siyuan/init 回傳的 ID)
SIYUAN_NB_DAILY_REPORTS=
SIYUAN_NB_SEMICONDUCTOR=
SIYUAN_NB_TMF_SIGNALS=
SIYUAN_NB_GEOPOLITICAL=
SIYUAN_NB_FINTEL_GRAPH=
